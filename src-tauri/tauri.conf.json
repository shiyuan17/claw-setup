{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claw Setup",
  "version": "0.1.0",
  "identifier": "cn.oneclaw.setup",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OneClaw Setup",
        "width": 580,
        "height": 680,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self'; script-src 'self'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/icon.png",
      "../assets/icon.icns",
      "../assets/icon.ico"
    ]
  }
}
